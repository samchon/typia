{
	"compilerOptions": {
		"target": "ESNext",
		"lib": ["esnext", "esnext.asynciterable", "DOM"],
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"resolveJsonModule": true,
		"types": ["vitest/importMeta", "vitest/globals"],
		"outDir": "lib",
		"strict": true,
		"strictNullChecks": true,
		"declaration": true,
		"esModuleInterop": true,
		"skipLibCheck": true
	},
	"include": ["src"]
}
