{
  "name": "@typia/ttsx",
  "version": "0.0.0-phase0",
  "description": "typia runner built on top of @typia/ttsc. Phase 0 spike.",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "bin": {
    "ttsx": "bin/ttsx.js"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf lib && tsc",
    "prepack": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/typia"
  },
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/typia/issues"
  },
  "homepage": "https://typia.io",
  "dependencies": {
    "@typia/transform": "workspace:^",
    "@typia/ttsc": "workspace:^",
    "typescript": "catalog:typescript"
  },
  "devDependencies": {
    "@types/node": "catalog:utils",
    "rimraf": "catalog:utils",
    "typescript": "catalog:typescript"
  },
  "sideEffects": false,
  "files": [
    "README.md",
    "package.json",
    "bin",
    "lib",
    "src"
  ],
  "keywords": [
    "typia",
    "typescript",
    "tsgo",
    "typescript-go",
    "runner",
    "ts-node",
    "tsx",
    "ttsx"
  ],
  "packageManager": "pnpm@10.6.4",
  "publishConfig": {
    "access": "public"
  }
}
