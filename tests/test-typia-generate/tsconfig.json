{
  "extends": "../config/tsconfig.json",
  "include": ["src"],
  "compilerOptions": {
    "rootDir": "src",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
  },
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "module": "commonjs",
      "moduleResolution": "nodenext",
    }
  },
}
