{
	"compilerOptions": {
		"target": "ESNext",
		"lib": [
			"esnext",
			"esnext.asynciterable",
			"DOM"
		],
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"resolveJsonModule": true,
		"outDir": "lib",
		"strict": true,
		"strictNullChecks": true,
		"declaration": true,
		"esModuleInterop": true,
		"isolatedDeclarations": true,
		"verbatimModuleSyntax": true,
		"erasableSyntaxOnly": true,
		"skipLibCheck": true
	},
	"include": ["src"],
}
