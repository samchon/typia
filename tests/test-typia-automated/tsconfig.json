{
  "extends": "../config/tsconfig.json",
  "compilerOptions": {
    "outDir": "bin",
    "rootDir": "src",
    "noEmit": false,
    "plugins": [
      { 
        "transform": "typia/lib/transform", 
        "functional": true, 
        "numeric": true, 
        "finite": true,
      },
    ]
  },
  "include": ["src"],
}