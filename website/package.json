{
  "private": true,
  "name": "@typia/website",
  "version": "13.0.0-dev.20260612.1",
  "description": "Typia Guide Documents",
  "scripts": {
    "build": "npm run build:prepare && next build && npm run build:finalize",
    "build:prepare": "rimraf .next && rimraf out && npm run build:compiler && npm run build:blog:rss && npm run build:examples",
    "build:finalize": "npm run build:pagefind && npm run build:sitemap",
    "build:blog:rss": "node build/blog",
    "build:compiler": "node build/compiler",
    "build:examples": "cd ../examples && pnpm run build",
    "build:pagefind": "pagefind --site .next/server/app --output-path out/_pagefind",
    "build:sitemap": "node build/sitemap",
    "build:tgz": "node build/tgz",
    "build:typedoc": "node build/typedoc",
    "deploy": "node build/deploy",
    "dev": "npm run build:compiler && npm run build:examples && next dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/typia"
  },
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/typia/issues"
  },
  "dependencies": {
    "@emotion/react": "^11.10.6",
    "@emotion/styled": "^11.10.6",
    "@monaco-editor/react": "^4.6.0",
    "@mui/icons-material": "^5.15.4",
    "@mui/material": "^5.12.0",
    "@mui/system": "^5.18.0",
    "@rollup/browser": "4.13.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@ttsc/playground": "catalog:typescript",
    "@ttsc/wasm": "catalog:typescript",
    "@typia/interface": "workspace:^",
    "@typia/legacy-transform": "npm:@typia/transform@12.0.2",
    "@typia/utils": "workspace:^",
    "lz-string": "^1.5.0",
    "monaco-editor": "^0.50.0",
    "next": "^15.3.4",
    "nextra": "^4.6.0",
    "nextra-theme-blog": "^4.6.1",
    "nextra-theme-docs": "^4.6.0",
    "path": "^0.12.7",
    "prettier": "^3.2.5",
    "postcss": "^8.5.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^4.1.12",
    "tgrid": "catalog:utils",
    "tstl": "catalog:utils",
    "typia": "workspace:^"
  },
  "devDependencies": {
    "@rspack/cli": "^1.0.0",
    "@rspack/core": "^1.0.0",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/node": "^18.11.10",
    "@types/prettier": "^3.0.0",
    "@types/react": "^18.0.35",
    "typescript": "catalog:typescript",
    "gh-pages": "^5.0.0",
    "next-sitemap": "^4.2.3",
    "pagefind": "^1.3.0",
    "process": "^0.11.10",
    "rimraf": "^5.0.0",
    "ts-loader": "^9.5.1",
    "typedoc": "^0.28.9",
    "typescript": "~5.9.3",
    "write-file-webpack-plugin": "^4.5.1"
  }
}
