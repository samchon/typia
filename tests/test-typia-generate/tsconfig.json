    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "typia/lib/internal/*": ["../../packages/typia/src/internal/*"]
    },
  },
  "include": ["src"],
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "module": "commonjs",
      "plugins": []
    }
  },
}
