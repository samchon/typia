{
  "name": "@typia/ttsc",
  "version": "0.0.0-phase0",
  "description": "typia transformer driver for TypeScript 7 (tsgo). Phase 0 spike.",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "bin": {
    "ttsc": "bin/ttsc.js"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf lib && tsc",
    "test": "pnpm run test:ts && pnpm run test:go",
    "test:ts": "node --test --test-reporter=spec --experimental-strip-types test/**/*.test.ts",
    "test:go": "bash -c 'export PATH=\"$HOME/go-sdk/go/bin:$PATH\"; go test ./...'",
    "go:build": "bash -c 'export PATH=\"$HOME/go-sdk/go/bin:$PATH\"; go build -o bin/ttsc-native ./cmd/ttsc'",
    "go:test": "bash -c 'export PATH=\"$HOME/go-sdk/go/bin:$PATH\"; go test ./...'",
    "go:vet": "bash -c 'export PATH=\"$HOME/go-sdk/go/bin:$PATH\"; go vet ./...'",
    "prepack": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/typia"
  },
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/typia/issues"
  },
  "homepage": "https://typia.io",
  "devDependencies": {
    "@types/node": "catalog:utils",
    "rimraf": "catalog:utils",
    "typescript": "catalog:typescript"
  },
  "sideEffects": false,
  "files": [
    "README.md",
    "THIRD-PARTY-LICENSES.md",
    "package.json",
    "bin",
    "lib",
    "src"
  ],
  "keywords": [
    "typia",
    "typescript",
    "tsgo",
    "typescript-go",
    "transformer",
    "ttsc"
  ],
  "packageManager": "pnpm@10.6.4",
  "publishConfig": {
    "access": "public"
  }
}
