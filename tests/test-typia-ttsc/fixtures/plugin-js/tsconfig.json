{
  "compilerOptions": {
    "module": "commonjs",
    "ignoreDeprecations": "6.0",
    "types": ["*"],
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "target": "ES2020",
    "plugins": [
      {
        "transform": "@ttsc/banner",
        "banner": "/* plugin-js */"
      }
    ]
  },
  "include": [
    "src/**/*.ts"
  ]
}
