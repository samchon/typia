{
  "compilerOptions": {
    "target": "ES2020",
    "module": "esnext",
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "outDir": "lib",
    "plugins": [
      {
        "transform": "typia/lib/transform"
      }
    ],
    "moduleResolution": "bundler"
  },
  "include": [
    "src/**/*.ts"
  ]
}
