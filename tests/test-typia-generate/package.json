{
  "private": true,
  "name": "@typia/test-typia-generate",
  "version": "12.0.0-dev.20260307-2",
  "description": "Test typia generation command",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-experimental-strip-types -r ts-node/register\" tsc",
    "generate": "node -r ./register.cjs node_modules/typia/src/executable/typia.ts generate --input src/input --output src/output",
    "start": "pnpm run generate && pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/typia"
  },
  "keywords": [
    "typia",
    "test"
  ],
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/typia/issues"
  },
  "homepage": "https://typia.io",
  "devDependencies": {
    "cross-env": "^7.0.3",
    "ts-node": "catalog:typescript",
    "typescript": "catalog:typescript"
  },
  "dependencies": {
    "typia": "workspace:^"
  }
}
